{
  "name": "business-news",
  "description": "Visualize RSS/Atom feeds",
  "version": "4.4.0",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "playwright test",
    "levitate": "npx @grafana/levitate@latest is-compatible --path src/module.ts --target @grafana/data,@grafana/runtime,@grafana/ui",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "start": "docker compose --profile dev up",
    "stop": "docker compose down",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --maxWorkers 4 --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:dev": "npx playwright test --ui",
    "test:e2e:docker": "docker compose --profile playwright up --build --force-recreate --abort-on-container-exit --exit-code-from playwright",
    "typecheck": "tsc --noEmit",
    "upgrade": "npm upgrade --save"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.4.12",
    "@grafana/tsconfig": "^2.0.1",
    "@playwright/test": "^1.59.0",
    "@swc/core": "^1.15.21",
    "@swc/helpers": "^0.5.20",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "copy-webpack-plugin": "^12.0.2",
    "cspell": "^10.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^52.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-webpack-plugin": "^5.0.3",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.2",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "^1.83.0",
    "sass-loader": "^16.0.4",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.2",
    "typescript": "5.7.2",
    "webpack": "^5.106.1",
    "webpack-cli": "^6.0.1",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.2.0-rc.1",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@grafana/data": "^12.4.2",
    "@grafana/runtime": "^12.4.2",
    "@grafana/schema": "^12.4.2",
    "@grafana/ui": "^12.4.2",
    "fast-xml-parser": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tslib": "^2.8.1"
  },
  "packageManager": "npm@11.9.0"
}
